# =============================================================================
# CONFIGURAÇÕES DA API - Aplicativo Mobile Pastelaria
# =============================================================================
# 
# Este arquivo contém as variáveis de ambiente necessárias para o funcionamento
# do aplicativo mobile. Copie este arquivo para .env e preencha os valores.
#
# IMPORTANTE: Nunca commite o arquivo .env com dados reais no Git!
#
# =============================================================================

# -----------------------------------------------------------------------------
# API - BACKEND
# -----------------------------------------------------------------------------

# URL base da API do backend da pastelaria
# 
# Exemplos de URLs para diferentes ambientes:
#
# - Desenvolvimento Local (Android Emulator):
#   EXPO_PUBLIC_API_BASE_URL="http://10.0.2.2:3333"
#
# - Desenvolvimento Local (iOS Simulator):
#   EXPO_PUBLIC_API_BASE_URL="http://localhost:3333"
#
# - Desenvolvimento Local (Dispositivo Físico na mesma rede):
#   EXPO_PUBLIC_API_BASE_URL="http://SEU_IP_LOCAL:3333"
#   Exemplo: http://192.168.1.100:3333
#
# - Produção (Servidor em nuvem):
#   EXPO_PUBLIC_API_BASE_URL="https://api.pastelaria.com.br"
#
# NOTA: Não inclua a barra (/) no final da URL
#
EXPO_PUBLIC_API_BASE_URL=""
