
# Porta do servidor
PORT=3333

# URL de conexão com o banco de dados PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database?sslmode=require
DATABASE_URL="postgresql://usuario:senha@localhost:5432/pastelaria?sslmode=require"

# Chave secreta para geração e validação de tokens JWT
# Use uma string aleatória e complexa em produção
JWT_SECRET="sua_chave_secreta_aqui_use_uma_string_aleatoria_e_complexa"

# Credenciais do Cloudinary para upload de imagens
# Obtenha suas credenciais em: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="sua_api_secret"